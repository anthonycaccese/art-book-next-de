<theme>

   <variables>
      <logoFont>./_inc/fonts/ChangaOne-Italic.ttf</logoFont>
      <bodyFont>./_inc/fonts/Oxygen-Bold.ttf</bodyFont>
      <spacerImage>./_inc/images/utility/space.png</spacerImage>
   </variables>

   <view name="system,gamelist">
      <helpsystem name="help">
         <pos>1 1</pos>
      </helpsystem>
   </view>

   <view name="system">
      <image name="background">
         <size>1 1</size>
         <pos>0 0</pos>
         <origin>0 0</origin>
         <path>${spacerImage}</path>
         <color>111111</color>
         <tile>true</tile>
      </image>
      <carousel name="system-carousel">
         <size>1 1</size>
         <pos>0 0</pos>
         <origin>0 0</origin>
         <color>00000000</color>
         <logo>./_inc/images/systems/${system.theme}.svg</logo>
         <logoScale>2</logoScale>
         <logoSize>0.25 0.15</logoSize>
         <maxLogoCount>2</maxLogoCount>
         <logoVerticalAlignment>center</logoVerticalAlignment>
         <text>${system.fullName}</text>
         <textColor>ffffff</textColor>
         <letterCase>uppercase</letterCase>
         <fontPath>${logoFont}</fontPath>
      </carousel>
      <image name="background-art">
         <size>0 1</size>
         <pos>0.5 0.5</pos>
         <origin>0.5 0.5</origin>
         <color>ffffffcc</color>
         <path>./_inc/images/systems/${system.theme}.png</path>
      </image>
      <image name="background-art-mask">
         <size>0 1</size>
         <pos>0.5 0</pos>
         <origin>0.5 0</origin>
         <path>./_inc/images/utility/background-art-mask.svg</path>
      </image>
   </view>

   <view name="gamelist">
      <image name="logo">
         <origin>0.5 0.5</origin>
         <zIndex>2</zIndex>
         <color>aaaaaa</color>
         <path>./_inc/images/systems/${system.theme}.svg</path>
         <zIndex>4</zIndex>
      </image>
      <!-- Gamelist Defaults -->
      <textlist name="gamelist">
         <origin>0 0</origin>
         <horizontalAlignment>left</horizontalAlignment>
         <fontPath>${bodyFont}</fontPath>
         <selectorColor>111111</selectorColor>
         <selectedColor>ffffff</selectedColor>
         <primaryColor>444444</primaryColor>
         <secondaryColor>444444</secondaryColor>
         <zIndex>4</zIndex>
      </textlist>
      <image name="gamelist-background">
         <pos>0 0</pos>
         <origin>0 0</origin>
         <path>${spacerImage}</path>
         <tile>true</tile>
         <color>111111</color>
         <zIndex>3</zIndex>
      </image>
      <image name="background">
         <origin>0 0</origin>
         <pos>0 0</pos>
         <size>1 1</size>
         <path>${spacerImage}</path>
         <tile>true</tile>
         <color>222222</color>
         <zIndex>0</zIndex>
      </image>
      <badges name="badges">
         <origin>1 0</origin>
         <horizontalAlignment>right</horizontalAlignment>
         <lines>1</lines>
         <slots>folder,broken,completed,favorite,kidgame,collection,controller,altemulator</slots>
         <customBadgeIcon badge="folder">./_inc/images/utility/badge-folder.svg</customBadgeIcon>
         <customBadgeIcon badge="broken">./_inc/images/utility/badge-broken.svg</customBadgeIcon>
         <customBadgeIcon badge="completed">./_inc/images/utility/badge-completed.svg</customBadgeIcon>
         <customBadgeIcon badge="favorite">./_inc/images/utility/badge-favorite.svg</customBadgeIcon>
         <customBadgeIcon badge="kidgame">./_inc/images/utility/badge-kidgame.svg</customBadgeIcon>
         <customBadgeIcon badge="collection">./_inc/images/utility/badge-collection.svg</customBadgeIcon>
         <customBadgeIcon badge="controller">./_inc/images/utility/badge-controller.svg</customBadgeIcon>
         <customBadgeIcon badge="altemulator">./_inc/images/utility/badge-altemulator.svg</customBadgeIcon>
      </badges>
      <!-- Media Defaults -->
      <image name="marquee">
         <imageType>marquee</imageType>
         <interpolation>linear</interpolation>
         <zIndex>2</zIndex>
      </image>
      <video name="video">
         <delay>1</delay>
         <imageType>screenshot,titlescreen,fanart,cover</imageType>
         <interpolation>linear</interpolation>
         <zIndex>1</zIndex>
      </video>
   </view>

   <!-- 16:9 Layout -->
   <aspectRatio name="16:9">
      <include>./16-9.xml</include>
   </aspectRatio>

   <!-- 16:10 Layout -->
   <aspectRatio name="16:10">
      <include>./16-10.xml</include>
   </aspectRatio>

   <!-- 4:3 Layout -->
   <aspectRatio name="4:3">
      <include>./4-3.xml</include>
   </aspectRatio>

</theme>