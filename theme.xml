<theme>

   <variables>
      <logoFont>./_inc/fonts/ChangaOne-Italic.ttf</logoFont>
      <bodyFont>./_inc/fonts/Oxygen-Bold.ttf</bodyFont>
      <spacerImage>./_inc/images/utility/space.png</spacerImage>
   </variables>

   <view name="system,gamelist">
      <helpsystem name="help">
         <pos>1 1</pos>
      </helpsystem>
   </view>

   <view name="system">
      <image name="background">
         <size>1 1</size>
         <pos>0 0</pos>
         <origin>0 0</origin>
         <path>${spacerImage}</path>
         <color>111111</color>
         <tile>true</tile>
      </image>
      <carousel name="system-carousel">
         <size>1 1</size>
         <pos>0 0</pos>
         <origin>0 0</origin>
         <color>00000000</color>
         <logo>./_inc/images/systems/logos/${system.theme}.svg</logo>
         <logoScale>1.4</logoScale>
         <logoSize>0.36 0.28125</logoSize>
         <maxLogoCount>1.8</maxLogoCount>
         <logoVerticalAlignment>center</logoVerticalAlignment>
         <text>${system.fullName}</text>
         <textColor>ffffff</textColor>
         <letterCase>uppercase</letterCase>
         <fontPath>${logoFont}</fontPath>
      </carousel>
      <image name="background-art">
         <size>0 1</size>
         <pos>0.5 0.5</pos>
         <origin>0.5 0.5</origin>
         <color>ffffffcc</color>
         <path>./_inc/images/systems/centered/${system.theme}.png</path>
         <default>./_inc/images/utility/default-background.jpg</default>
      </image>
      <image name="background-art-mask">
         <size>0 1</size>
         <pos>0.5 0</pos>
         <origin>0.5 0</origin>
         <path>./_inc/images/utility/centered-background-mask.svg</path>
      </image>
   </view>

   <view name="gamelist">
      <image name="logo">
         <origin>0.5 0.5</origin>
         <zIndex>2</zIndex>
         <color>aaaaaa</color>
         <path>./_inc/images/systems/logos/${system.theme}.svg</path>
         <zIndex>4</zIndex>
      </image>
      <!-- Gamelist Defaults -->
      <textlist name="gamelist">
         <origin>0 0</origin>
         <horizontalAlignment>left</horizontalAlignment>
         <fontPath>${bodyFont}</fontPath>
         <horizontalMargin>0.008</horizontalMargin>
         <selectorColor>111111</selectorColor>
         <selectedColor>ffffff</selectedColor>
         <primaryColor>444444</primaryColor>
         <secondaryColor>444444</secondaryColor>
         <zIndex>4</zIndex>
      </textlist>
      <image name="gamelist-background">
         <pos>0 0</pos>
         <origin>0 0</origin>
         <path>${spacerImage}</path>
         <tile>true</tile>
         <color>111111</color>
         <zIndex>3</zIndex>
      </image>
      <image name="gamelist-border">
         <origin>0 0</origin>
         <path>${spacerImage}</path>
         <tile>true</tile>
         <color>000000</color>
         <zIndex>3</zIndex>
      </image>
      <!-- Media Defaults -->
      <image name="marquee">
         <origin>0.5 0.5</origin>
         <imageType>marquee</imageType>
         <zIndex>2</zIndex>
      </image>
      <video name="video">
         <origin>0.5 0.5</origin>
         <delay>1</delay>
         <defaultImage>./_inc/images/utility/default-background.jpg</defaultImage>
         <imageType>screenshot,titlescreen,fanart,cover</imageType>
         <zIndex>1</zIndex>
      </video>
   </view>

   <!-- 16:9 Layout -->
   <aspectRatio name="16:9">
      <include>./16-9.xml</include>
   </aspectRatio>

   <!-- 4:3 Layout -->
   <aspectRatio name="4:3">
      <include>./4-3.xml</include>
   </aspectRatio>

</theme>